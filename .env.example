# ─── META / INSTAGRAM ────────────────────────────────────────────────────────
# Token que escribiste en Meta for Developers al configurar el webhook
META_VERIFY_TOKEN=tu_token_de_verificacion

# App Secret — está en Meta for Developers > Configuración de la app > Básica
META_APP_SECRET=tu_app_secret

# Token de acceso de página (el que generaste en el Paso 2 de Meta)
IG_ACCESS_TOKEN=tu_token_de_instagram

# ─── ODOO ─────────────────────────────────────────────────────────────────────
# URL de tu instancia sin barra final
ODOO_URL=https://clevercnc.odoo.com

# API Key generada en Odoo > Configuración > Técnico > Claves API
ODOO_API_KEY=tu_api_key_de_odoo

# Nombre de la base de datos de Odoo (visible en la URL o en Configuración)
ODOO_DB=clevercnc

# ID del canal de Live Chat (el número de la URL al editar el canal)
ODOO_LIVECHAT_CHANNEL_ID=1
